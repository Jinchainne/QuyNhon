# AI router / ChainOpera OpenAI-compatible
AI_API_KEY=
AI_BASE_URL=https://router.chainopera.ai/v1
AI_MODEL=Qwen3-32B

# SoSoValue research
SOSOVALUE_API_KEY=

# SoDEX trading/account
SODEX_API_KEY_NAME=
SODEX_PUBLIC_KEY=
SODEX_API_PRIVATE_KEY=
# Optional aliases accepted by server:
# SODEX_PRIVATE_KEY=
# SODEX_WALLET_PRIVATE_KEY=

# Secure live execution gate
ENABLE_LIVE_TRADING=false
ADMIN_SECRET=
ADMIN_WALLET=
AUTOMATION_SECRET=
MAX_ORDER_NOTIONAL_USD=100
MAX_LEVERAGE=5

NEXT_PUBLIC_APP_URL=
AUTO_TRADE_CONFIG={"market":"BTCUSDT","product":"futures","side":"long","orderType":"limit","amount":"0.001","leverage":2,"futuresAutoClose":"time","futuresCloseMinutes":"15","action":"preview"}

# JINBOT_SODEX CROSS local/Telegram bridge
# Start Jinbot locally, then expose a local HTTP bridge if it has one. Default tried by QuyNhon AI: http://127.0.0.1:8787
JINBOT_BRIDGE_URL=http://127.0.0.1:8787
JINBOT_BRIDGE_SECRET=
JINBOT_STATE_PATH=
JINBOT_PANEL_SECRET=
JINBOT_TELEGRAM_BOT_TOKEN=
JINBOT_TELEGRAM_CHAT_ID=
